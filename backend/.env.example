# Local PostgreSQL (Windows installer / default superuser). Đổi port/mật khẩu nếu máy bạn khác.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/vnindex_signal
DATABASE_URL_SYNC=postgresql://postgres:postgres@127.0.0.1:5432/vnindex_signal
API_SECRET_KEY=your-secret-key-here
BCRYPT_ROUNDS=12
CORS_ORIGINS=["http://localhost:3000"]

# Fireant REST (Bearer JWT). Nếu để trống, backend dùng JWT mặc định (dev) trong fireant_quote_service / run_analysis.py
FIREANT_TOKEN=
