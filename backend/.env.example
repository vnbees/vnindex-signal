# Local PostgreSQL (Windows installer / default superuser). Đổi port/mật khẩu nếu máy bạn khác.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/vnindex_signal
DATABASE_URL_SYNC=postgresql://postgres:postgres@127.0.0.1:5432/vnindex_signal
API_SECRET_KEY=your-secret-key-here
BCRYPT_ROUNDS=12
CORS_ORIGINS=["http://localhost:3000"]

# Fireant REST (Bearer JWT). Nếu để trống, backend dùng JWT mặc định (dev) trong fireant_quote_service / run_analysis.py
FIREANT_TOKEN=
FIREANT_API_BASE=https://api.fireant.vn
REVIEW_V2_CACHE_TTL_SECONDS=900

# Daily automation (balanced pipeline — snapshot-only, không cần Gemini)
AUTOMATION_TOKEN=replace-with-long-random-secret
AUTOMATION_BASE_URL=https://vnindex-signal-production.up.railway.app
AUTOMATION_HTTP_TIMEOUT_SECONDS=120

# Chỉ cần cho script smoke `scripts/debug_gemini_daily_io.py`, không dùng bởi `/automation/daily-balanced-run`.
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
