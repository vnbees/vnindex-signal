# Phải trỏ tới FastAPI (thường cổng 8000), không đặt cổng 3000 (Next).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Chỉ dùng khi frontend chạy trong Docker Compose (hostname `backend`). Khi `npm run dev` trên máy: để trống hoặc = http://localhost:8000 — nếu để http://backend:8000 trang admin có thể treo/tải rất lâu.
API_URL_INTERNAL=
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
